# ===================================
# CMS Platform Environment Configuration
# ===================================

# Application
NODE_ENV=development
PORT=3000
API_VERSION=v1
LOG_LEVEL=debug

# ===================================
# Database - PostgreSQL
# ===================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=cms_admin
POSTGRES_PASSWORD=CHANGEME_postgres_secret
POSTGRES_DB=cms_platform
POSTGRES_SSL=false
POSTGRES_POOL_MIN=2
POSTGRES_POOL_MAX=20

# ===================================
# Database - MongoDB
# ===================================
MONGO_URI=mongodb://localhost:27017/cms_content
MONGO_USER=cms_mongo
MONGO_PASSWORD=CHANGEME_mongo_secret

# ===================================
# Redis
# ===================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=CHANGEME_redis_secret
REDIS_DB=0
REDIS_CLUSTER=false

# ===================================
# ElasticSearch
# ===================================
ELASTICSEARCH_NODE=http://localhost:9200
ELASTICSEARCH_USER=elastic
ELASTICSEARCH_PASSWORD=CHANGEME_elastic_secret

# ===================================
# Object Storage (S3-compatible)
# ===================================
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=CHANGEME_s3_access
S3_SECRET_KEY=CHANGEME_s3_secret
S3_BUCKET=cms-media
S3_REGION=us-east-1

# ===================================
# Authentication
# ===================================
JWT_SECRET=CHANGEME_jwt_secret_min_32_chars_long
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=CHANGEME_refresh_secret_min_32_chars
REFRESH_TOKEN_EXPIRES_IN=7d

# ===================================
# Encryption
# ===================================
ENCRYPTION_KEY=CHANGEME_encryption_key_32_bytes!
ENCRYPTION_ALGORITHM=aes-256-gcm

# ===================================
# Event Bus
# ===================================
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=cms-platform
KAFKA_GROUP_ID=cms-consumers
NATS_URL=nats://localhost:4222

# ===================================
# Email (SMTP)
# ===================================
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@cms-platform.local

# ===================================
# Rate Limiting
# ===================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ===================================
# Billing (Stripe)
# ===================================
STRIPE_SECRET_KEY=sk_test_CHANGEME
STRIPE_WEBHOOK_SECRET=whsec_CHANGEME
STRIPE_PUBLISHABLE_KEY=pk_test_CHANGEME

# ===================================
# External Services
# ===================================
AI_API_KEY=CHANGEME_ai_key
AI_MODEL=gpt-4
AI_BASE_URL=https://api.openai.com/v1

# ===================================
# Observability
# ===================================
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=cms-platform
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001

# ===================================
# Service URLs (internal)
# ===================================
AUTH_SERVICE_URL=http://localhost:3001
USER_SERVICE_URL=http://localhost:3002
TENANT_SERVICE_URL=http://localhost:3003
CONTENT_SERVICE_URL=http://localhost:3004
MEDIA_SERVICE_URL=http://localhost:3005
ANALYTICS_SERVICE_URL=http://localhost:3006
COMMENT_SERVICE_URL=http://localhost:3007
NOTIFICATION_SERVICE_URL=http://localhost:3008
SEARCH_SERVICE_URL=http://localhost:3009
WORKFLOW_SERVICE_URL=http://localhost:3010
PLUGIN_SERVICE_URL=http://localhost:3011
FEATURE_SERVICE_URL=http://localhost:3012
AUDIT_SERVICE_URL=http://localhost:3013
SETTINGS_SERVICE_URL=http://localhost:3014
AI_SERVICE_URL=http://localhost:3015
