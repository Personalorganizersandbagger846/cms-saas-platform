# ─── Build Stage ──────────────────────
FROM node:20-alpine AS builder

ARG SERVICE_NAME

RUN corepack enable && corepack prepare pnpm@9 --activate

WORKDIR /app

# Copy workspace root files
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml turbo.json tsconfig.json ./

# Copy all packages (shared libs)
COPY packages/ packages/

# Copy the target service
COPY apps/${SERVICE_NAME}/ apps/${SERVICE_NAME}/

# Install dependencies
RUN pnpm install --frozen-lockfile --filter @cms/${SERVICE_NAME}...

# Build all packages then the service
RUN pnpm turbo build --filter @cms/${SERVICE_NAME}...

# Prune dev dependencies
RUN pnpm prune --prod

# ─── Production Stage ────────────────
FROM node:20-alpine AS runner

RUN apk add --no-cache tini curl

ARG SERVICE_NAME
ENV NODE_ENV=production
ENV SERVICE_NAME=${SERVICE_NAME}

WORKDIR /app

# Copy built output
COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/packages ./packages
COPY --from=builder /app/apps/${SERVICE_NAME} ./apps/${SERVICE_NAME}

# Run as non-root
RUN addgroup -g 1001 -S cms && adduser -S cms -u 1001
USER cms

ENTRYPOINT ["/sbin/tini", "--"]
CMD ["node", "apps/${SERVICE_NAME}/dist/index.js"]
